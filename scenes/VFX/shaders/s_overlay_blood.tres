code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform bool Use_UV2 = false;
uniform vec2 Texture_Scale_XY = vec2(1.000000, 1.000000);
uniform vec2 Texture_Offset_XY;
uniform sampler2D Texture : source_color, repeat_enable;
uniform sampler2D Texture_Add : source_color, hint_default_black, repeat_disable;
uniform float Multiply_Edge : hint_range(0.0, 1.0) = 0.0;
uniform vec2 Mask_Scale_XY = vec2(1.000000, 1.000000);
uniform vec2 Mask_Offset_XY;
uniform sampler2D Texture_Mask : source_color, repeat_disable;
uniform float Mask_Power = 1.0;
uniform sampler2D Color_1D_Gradient : source_color, repeat_disable;
uniform sampler2D Texture_Rougthness : source_color, repeat_disable;
uniform sampler2D Texture_Normal : hint_normal, repeat_enable;
uniform float Normal_Intensity = 1.0;



void fragment() {
// BooleanParameter:45
	bool n_out45p0 = Use_UV2;


// Input:43
	vec2 n_out43p0 = UV2;


// Input:42
	vec2 n_out42p0 = UV;


	vec2 n_out44p0;
// Switch:44
	n_out44p0 = mix(n_out42p0, n_out43p0, float(n_out45p0));


// Vector2Parameter:15
	vec2 n_out15p0 = Texture_Scale_XY;


// UVFunc:11
	vec2 n_in11p2 = vec2(0.00000, 0.00000);
	vec2 n_out11p0 = (n_out44p0 - n_in11p2) * n_out15p0 + n_in11p2;


// Vector2Parameter:13
	vec2 n_out13p0 = Texture_Offset_XY;


// UVFunc:10
	vec2 n_in10p1 = vec2(1.00000, 1.00000);
	vec2 n_out10p0 = n_out13p0 * n_in10p1 + n_out11p0;


	vec4 n_out8p0;
// Texture2D:8
	n_out8p0 = texture(Texture, n_out10p0);
	float n_out8p1 = n_out8p0.r;


	vec4 n_out24p0;
// Texture2D:24
	n_out24p0 = texture(Texture_Add, n_out44p0);
	float n_out24p1 = n_out24p0.r;


// FloatOp:27
	float n_out27p0 = n_out8p1 + n_out24p1;


// FloatParameter:41
	float n_out41p0 = Multiply_Edge;


// Vector2Parameter:39
	vec2 n_out39p0 = Mask_Scale_XY;


// UVFunc:37
	vec2 n_in37p2 = vec2(0.00000, 0.00000);
	vec2 n_out37p0 = (n_out44p0 - n_in37p2) * n_out39p0 + n_in37p2;


// Vector2Parameter:38
	vec2 n_out38p0 = Mask_Offset_XY;


// UVFunc:36
	vec2 n_in36p1 = vec2(1.00000, 1.00000);
	vec2 n_out36p0 = n_out38p0 * n_in36p1 + n_out37p0;


	vec4 n_out26p0;
// Texture2D:26
	n_out26p0 = texture(Texture_Mask, n_out36p0);
	float n_out26p1 = n_out26p0.r;


// FloatParameter:48
	float n_out48p0 = Mask_Power;


// FloatOp:47
	float n_out47p0 = pow(n_out26p1, n_out48p0);


// SmoothStep:40
	float n_in40p1 = 1.00000;
	float n_out40p0 = smoothstep(n_out41p0, n_in40p1, n_out47p0);


// FloatOp:28
	float n_out28p0 = n_out27p0 * n_out40p0;


// Clamp:34
	float n_in34p1 = 0.00000;
	float n_in34p2 = 1.00000;
	float n_out34p0 = clamp(n_out28p0, n_in34p1, n_in34p2);


	vec4 n_out22p0;
// Texture2D:22
	n_out22p0 = texture(Color_1D_Gradient, vec2(n_out34p0));
	float n_out22p4 = n_out22p0.a;


	vec4 n_out31p0;
// Texture2D:31
	n_out31p0 = texture(Texture_Rougthness, n_out44p0);
	float n_out31p1 = n_out31p0.r;


// FloatOp:46
	float n_in46p1 = 0.10000;
	float n_out46p0 = pow(n_out22p4, n_in46p1);


	vec4 n_out30p0;
// Texture2D:30
	n_out30p0 = texture(Texture_Normal, n_out44p0);


// FloatParameter:33
	float n_out33p0 = Normal_Intensity;


// Output:0
	ALBEDO = vec3(n_out22p0.xyz);
	ALPHA = n_out22p4;
	ROUGHNESS = n_out31p1;
	SPECULAR = n_out46p0;
	NORMAL_MAP = vec3(n_out30p0.xyz);
	NORMAL_MAP_DEPTH = n_out33p0;


}
"
