code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx, unshaded;

uniform vec2 Scale = vec2(1.000000, 1.000000);
uniform vec2 Speed_XY;
uniform sampler2D Disolver_Texture : source_color, repeat_enable;
uniform sampler2D Multiply_Mask : source_color, repeat_disable;
uniform sampler2D Color_1D_Gradient : source_color, repeat_disable;



void vertex() {
// GetBillboardMatrix:2
	// Node is disabled and code is not generated.
}

void fragment() {
// Vector2Parameter:16
	vec2 n_out16p0 = Scale;


// UVFunc:15
	vec2 n_in15p2 = vec2(0.00000, 0.00000);
	vec2 n_out15p0 = (UV - n_in15p2) * n_out16p0 + n_in15p2;


// Vector2Parameter:21
	vec2 n_out21p0 = Speed_XY;


// Input:31
	float n_out31p0 = TIME;


// VectorOp:32
	vec2 n_out32p0 = n_out21p0 * vec2(n_out31p0);


// UVFunc:20
	vec2 n_in20p1 = vec2(1.00000, 1.00000);
	vec2 n_out20p0 = n_out32p0 * n_in20p1 + n_out15p0;


	vec4 n_out10p0;
// Texture2D:10
	n_out10p0 = texture(Disolver_Texture, n_out20p0);
	float n_out10p1 = n_out10p0.r;


	vec4 n_out18p0;
// Texture2D:18
	n_out18p0 = texture(Multiply_Mask, UV);
	float n_out18p1 = n_out18p0.r;


// FloatOp:19
	float n_out19p0 = n_out10p1 * n_out18p1;


	vec4 n_out30p0;
// Texture2D:30
	n_out30p0 = texture(Color_1D_Gradient, vec2(n_out19p0));


// Input:4
	vec4 n_out4p0 = COLOR;
	float n_out4p4 = n_out4p0.a;


// VectorOp:33
	vec3 n_out33p0 = vec3(n_out30p0.xyz) * vec3(n_out4p0.xyz);


// Output:0
	ALBEDO = n_out33p0;
	ALPHA = n_out19p0;
	ALPHA_SCISSOR_THRESHOLD = n_out4p4;


}
