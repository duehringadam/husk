// FloatParameter:39
	float n_out39p0 = Fresnel_Power;


// Fresnel:37
	float n_out37p0 = n_out40p0 ? (pow(clamp(dot(NORMAL, VIEW), 0.0, 1.0), n_out39p0)) : (pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), n_out39p0));


// Vector2Parameter:16
	vec2 n_out16p0 = Scale;


// UVFunc:15
	vec2 n_in15p2 = vec2(0.00000, 0.00000);
	vec2 n_out15p0 = (UV - n_in15p2) * n_out16p0 + n_in15p2;


// Vector2Parameter:21
	vec2 n_out21p0 = Speed_XY;


// Input:31
	float n_out31p0 = TIME;


// VectorOp:32
	vec2 n_out32p0 = n_out21p0 * vec2(n_out31p0);


// UVFunc:20
	vec2 n_in20p1 = vec2(1.00000, 1.00000);
	vec2 n_out20p0 = n_out32p0 * n_in20p1 + n_out15p0;


	vec4 n_out10p0;
// Texture2D:10
	n_out10p0 = texture(Disolver_Texture, n_out20p0);
	float n_out10p1 = n_out10p0.r;


	float n_out41p0;
// Switch:41
	n_out41p0 = mix(n_out10p1, n_out37p0, float(n_out42p0));


	vec4 n_out30p0;
// Texture2D:30
	n_out30p0 = texture(Color_1D_Gradient, vec2(n_out41p0));


// Input:36
	vec4 n_out36p0 = COLOR;


// VectorOp:35
	vec3 n_out35p0 = vec3(n_out30p0.xyz) * vec3(n_out36p0.xyz);


	vec4 n_out18p0;
// Texture2D:18
	n_out18p0 = texture(Multiply_Mask, UV);
	float n_out18p1 = n_out18p0.r;


// FloatOp:19
	float n_out19p0 = n_out10p1 * n_out18p1;


// Reroute:28
	vec2 n_out28p0 = n_out20p0;


	vec4 n_out26p0;
// Texture2D:26
	n_out26p0 = texture(Metallic_Texture, n_out28p0);
	float n_out26p1 = n_out26p0.r;


	vec4 n_out25p0;
// Texture2D:25
	n_out25p0 = texture(Texture_Roughtness, n_out28p0);
	float n_out25p1 = n_out25p0.r;


	vec4 n_out34p0;
// Texture2D:34
	n_out34p0 = texture(Roughtness_1D_Gradient, vec2(n_out25p1));
	float n_out34p1 = n_out34p0.r;


	vec4 n_out23p0;
// Texture2D:23
	n_out23p0 = texture(Normal_Texture, n_out28p0);


// Input:4
	vec4 n_out4p0 = COLOR;
	float n_out4p4 = n_out4p0.a;


// Output:0
	ALBEDO = n_out35p0;
	ALPHA = n_out19p0;
	METALLIC = n_out26p1;
	ROUGHNESS = n_out34p1;
	NORMAL_MAP = vec3(n_out23p0.xyz);
	ALPHA_SCISSOR_THRESHOLD = n_out4p4;


}
